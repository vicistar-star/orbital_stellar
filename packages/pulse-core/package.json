    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^3.22.0",
    "pg": "^8.11.5",
    "tsx": "^4.21.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
